---
const { currentPage = '' } = Astro.props;
---

<nav id="nav" class="fixed top-0 inset-x-0 z-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">

    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center flex-shrink-0">
        <img src="/logo.svg" alt="Vylo" height="38" style="height:38px; width:auto;" />
      </a>

      <!-- Centre links -->
      <div class="hidden md:flex items-center gap-7 text-[13px] text-white/60">
        <a href="/#features" class="hover:text-white transition-colors">Features</a>
        <a href="/#security" class="hover:text-white transition-colors">Security</a>
        <a href="/#faq"      class="hover:text-white transition-colors">FAQ</a>
        <a href="/updates"
           class:list={['hover:text-white transition-colors', { 'text-white': currentPage === 'updates' }]}>
          Updates
        </a>
      </div>

      <!-- Right CTAs -->
      <div class="hidden md:flex items-center gap-3">
        <a href="https://app.myvylo.com/signin"
           class="text-[13px] text-white/60 hover:text-white transition-colors px-3 py-1.5">
          Sign in
        </a>
        <a href="https://app.myvylo.com/signup"
           class="button-shimmer text-[13px] font-semibold bg-indigo-500 hover:bg-indigo-400 text-white px-4 py-2 rounded-lg transition-colors">
          Get started free
        </a>
      </div>

      <!-- Hamburger -->
      <button id="menu-btn" class="md:hidden p-2 text-white/60 hover:text-white" aria-label="Toggle menu">
        <svg id="icon-open"  width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M3 6h14M3 10h14M3 14h14" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/></svg>
        <svg id="icon-close" class="hidden" width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/></svg>
      </button>
    </div>

    <!-- Mobile drawer -->
    <div id="mobile-menu">
      <div class="flex flex-col gap-1 pb-4 pt-2 border-t border-white/[0.06]">
        <a href="/#features" onclick="closeMobileMenu()" class="px-2 py-2.5 text-sm text-white/65 hover:text-white">Features</a>
        <a href="/#security" onclick="closeMobileMenu()" class="px-2 py-2.5 text-sm text-white/65 hover:text-white">Security</a>
        <a href="/#faq"      onclick="closeMobileMenu()" class="px-2 py-2.5 text-sm text-white/65 hover:text-white">FAQ</a>
        <a href="/updates"   onclick="closeMobileMenu()" class="px-2 py-2.5 text-sm text-white/65 hover:text-white">Updates</a>
        <div class="pt-2 flex flex-col gap-2">
          <a href="https://app.myvylo.com/signin"
             class="py-2.5 text-sm text-center text-white/65 border border-white/10 rounded-lg hover:border-white/20">
            Sign in
          </a>
          <a href="https://app.myvylo.com/signup"
             class="button-shimmer py-2.5 text-sm text-center font-semibold bg-indigo-500 hover:bg-indigo-400 text-white rounded-lg transition-colors">
            Get started free
          </a>
        </div>
      </div>
    </div>

  </div>
</nav>

<script>
  const nav      = document.getElementById('nav')!;
  const menuBtn  = document.getElementById('menu-btn')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const iconOpen  = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 24);
  }, { passive: true });

  menuBtn.addEventListener('click', () => {
    const open = mobileMenu.classList.toggle('open');
    iconOpen.classList.toggle('hidden', open);
    iconClose.classList.toggle('hidden', !open);
  });

  document.addEventListener('click', e => {
    if (!menuBtn.contains(e.target as Node) && !mobileMenu.contains(e.target as Node)) {
      closeMobileMenu();
    }
  });

  function closeMobileMenu() {
    mobileMenu.classList.remove('open');
    iconOpen.classList.remove('hidden');
    iconClose.classList.add('hidden');
  }

  (window as any).closeMobileMenu = closeMobileMenu;
</script>
