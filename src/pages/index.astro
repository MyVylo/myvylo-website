<script>
  // Hero indicator dots
  const dots = document.querySelectorAll('.dot');
  function updateDots() {
    const phase = Math.floor((Date.now() / 1000) % 9 / 3);
    dots.forEach((d, i) => {
      d.classList.toggle('bg-indigo-400', i === phase);
      d.classList.toggle('bg-white/20',   i !== phase);
    });
  }
  setInterval(updateDots, 120);
  updateDots();

  // FAQ accordion
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const answer = btn.nextElementSibling as HTMLElement;
      const icon   = btn.querySelector('.faq-icon')!;
      const isOpen = answer.classList.toggle('open');
      icon.classList.toggle('open', isOpen);
      btn.closest('#faq-list')!.querySelectorAll('.faq-answer').forEach(a => {
        if (a !== answer) {
          a.classList.remove('open');
          (a.previousElementSibling as HTMLElement).querySelector('.faq-icon')!.classList.remove('open');
        }
      });
    });
  });
</script>

