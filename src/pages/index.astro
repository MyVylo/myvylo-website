---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Vylo – Finance tracking that knows its place."
  description="Connect your bank once. Every transaction shows up, automatically categorized and tracked. No spreadsheets. No dashboards. Just clarity."
>

<!-- ════════════════════════════════════════════════════════════════
     HERO
════════════════════════════════════════════════════════════════ -->
<section class="hero-glow relative overflow-hidden pt-32 pb-20 px-4 sm:px-6">
  <div class="bg-grid absolute inset-0 pointer-events-none"></div>

  <div class="max-w-6xl mx-auto relative">
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">

      <!-- Copy -->
      <div class="flex-1 text-center lg:text-left max-w-xl mx-auto lg:mx-0">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full
                    bg-indigo-500/10 border border-indigo-500/20
                    text-indigo-300 text-xs font-medium mb-6 fade-in-up">
          <span class="w-1.5 h-1.5 rounded-full bg-indigo-400 animate-pulse"></span>
          Finance, without the noise.
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-[54px] font-bold leading-[1.1] tracking-tight gradient-text mb-5 fade-in-up delay-100">
          Finance tracking<br/>that knows<br/>its place.
        </h1>

        <p class="text-white/55 text-lg leading-relaxed mb-8 fade-in-up delay-200">
          Connect your accounts once. Every transaction shows up,
          categorized and tracked, automatically. No spreadsheets.
          No dashboards. No Sunday night catch-up sessions.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 justify-center lg:justify-start fade-in-up delay-300">
          <a href="https://app.myvylo.com/signup"
             class="button-shimmer px-6 py-3 bg-indigo-500 hover:bg-indigo-400 text-white text-sm font-semibold
                    rounded-xl transition-all duration-200 hover:shadow-lg hover:shadow-indigo-500/25 hover:-translate-y-0.5">
            Get started — it's free
          </a>
          <a href="#features"
             class="px-6 py-3 border border-white/10 hover:border-white/25 text-white/75
                    hover:text-white text-sm font-medium rounded-xl transition-all duration-200">
            See how it works
          </a>
        </div>

        <p class="mt-5 text-xs text-white/30 fade-in-up delay-400">
          Bank-level encryption · Powered by Plaid · No credit card required
        </p>
      </div>

      <!-- App mockup -->
      <div class="flex-1 w-full max-w-[420px] lg:max-w-none mx-auto lg:mx-0">
        <div class="relative" style="max-width:420px; margin:0 auto;">
          <div class="absolute -inset-6 rounded-3xl bg-indigo-500/10 blur-3xl pointer-events-none"></div>

          <div class="relative glass rounded-2xl card-glow overflow-hidden">
            <!-- Window chrome -->
            <div class="flex items-center gap-1.5 px-4 py-3 border-b border-white/[0.06]">
              <div class="w-2.5 h-2.5 rounded-full bg-red-500/50"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/50"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-green-500/50"></div>
              <div class="ml-3 flex-1 bg-white/[0.05] rounded h-5 flex items-center px-2.5">
                <span class="text-[10px] text-white/25 font-mono">app.myvylo.com</span>
              </div>
            </div>

            <div class="relative p-4" style="min-height:340px;">

              <!-- Screen 1: Dashboard -->
              <div class="screen-1 absolute inset-4">
                <p class="text-[10px] uppercase tracking-widest text-white/35 font-semibold mb-1">Total spend · March</p>
                <p class="text-2xl font-bold font-mono text-white mb-4">$3,241<span class="text-sm text-white/35 font-sans font-normal">.58</span></p>
                <div class="flex items-end gap-1.5 h-20 mb-4">
                  <div class="flex-1 rounded-t-sm bg-indigo-500/25" style="height:42%"></div>
                  <div class="flex-1 rounded-t-sm bg-indigo-500/30" style="height:60%"></div>
                  <div class="flex-1 rounded-t-sm bg-indigo-500/25" style="height:38%"></div>
                  <div class="flex-1 rounded-t-sm bg-indigo-500/35" style="height:75%"></div>
                  <div class="flex-1 rounded-t-sm bg-indigo-500/30" style="height:52%"></div>
                  <div class="flex-1 rounded-t-sm bg-indigo-500/45" style="height:88%"></div>
                  <div class="flex-1 rounded-t-sm bg-indigo-500"    style="height:68%"></div>
                </div>
                <div class="space-y-2">
                  <div class="flex items-center justify-between">
                    <div class="flex items-center gap-2"><div class="w-2 h-2 rounded-full bg-indigo-400"></div><span class="text-[11px] text-white/70">Groceries</span></div>
                    <span class="text-[11px] font-mono text-white">$842</span>
                  </div>
                  <div class="flex items-center justify-between">
                    <div class="flex items-center gap-2"><div class="w-2 h-2 rounded-full bg-emerald-400"></div><span class="text-[11px] text-white/70">Dining out</span></div>
                    <span class="text-[11px] font-mono text-white">$614</span>
                  </div>
                  <div class="flex items-center justify-between">
                    <div class="flex items-center gap-2"><div class="w-2 h-2 rounded-full bg-amber-400"></div><span class="text-[11px] text-white/70">Transport</span></div>
                    <span class="text-[11px] font-mono text-white">$390</span>
                  </div>
                </div>
              </div>

              <!-- Screen 2: Auto-categorization -->
              <div class="screen-2 absolute inset-4">
                <p class="text-[10px] uppercase tracking-widest text-white/35 font-semibold mb-3">Auto-categorizing</p>
                <div class="space-y-2">
                  <div class="flex items-center justify-between p-2.5 rounded-lg bg-white/[0.04] border border-white/[0.06]">
                    <div class="flex items-center gap-2.5">
                      <div class="w-7 h-7 rounded-md bg-emerald-500/20 text-emerald-400 text-[11px] font-bold flex items-center justify-center">W</div>
                      <div><p class="text-[11px] text-white font-medium">Whole Foods</p><p class="text-[10px] text-white/40">→ Groceries</p></div>
                    </div>
                    <span class="text-[11px] font-mono text-white">$67.43</span>
                  </div>
                  <div class="flex items-center justify-between p-2.5 rounded-lg bg-white/[0.04] border border-white/[0.06]">
                    <div class="flex items-center gap-2.5">
                      <div class="w-7 h-7 rounded-md bg-amber-500/20 text-amber-400 text-[11px] font-bold flex items-center justify-center">U</div>
                      <div><p class="text-[11px] text-white font-medium">Uber</p><p class="text-[10px] text-white/40">→ Transport</p></div>
                    </div>
                    <span class="text-[11px] font-mono text-white">$14.20</span>
                  </div>
                  <div class="flex items-center justify-between p-2.5 rounded-lg bg-indigo-500/10 border border-indigo-500/25">
                    <div class="flex items-center gap-2.5">
                      <div class="w-7 h-7 rounded-md bg-indigo-500/20 text-indigo-400 text-[11px] font-bold flex items-center justify-center">N</div>
                      <div><p class="text-[11px] text-white font-medium">Netflix</p><p class="text-[10px] text-indigo-400">→ Subscriptions ✓</p></div>
                    </div>
                    <span class="text-[11px] font-mono text-white">$15.99</span>
                  </div>
                  <div class="flex items-center justify-between p-2.5 rounded-lg bg-white/[0.04] border border-white/[0.06]">
                    <div class="flex items-center gap-2.5">
                      <div class="w-7 h-7 rounded-md bg-rose-500/20 text-rose-400 text-[11px] font-bold flex items-center justify-center">S</div>
                      <div><p class="text-[11px] text-white font-medium">Sweetgreen</p><p class="text-[10px] text-white/40">→ Dining out</p></div>
                    </div>
                    <span class="text-[11px] font-mono text-white">$18.75</span>
                  </div>
                </div>
              </div>

              <!-- Screen 3: Budget insights -->
              <div class="screen-3 absolute inset-4">
                <p class="text-[10px] uppercase tracking-widest text-white/35 font-semibold mb-3">Budget progress · March</p>
                <div class="space-y-3.5">
                  <div>
                    <div class="flex justify-between mb-1.5"><span class="text-[11px] text-white/75">Groceries</span><span class="text-[11px] font-mono text-white">$842 <span class="text-white/35">/ $1,000</span></span></div>
                    <div class="h-1.5 bg-white/10 rounded-full overflow-hidden"><div class="h-full bg-emerald-400 rounded-full" style="width:84%"></div></div>
                  </div>
                  <div>
                    <div class="flex justify-between mb-1.5"><span class="text-[11px] text-white/75">Dining out</span><span class="text-[11px] font-mono text-amber-400">$614 <span class="text-white/35">/ $600</span></span></div>
                    <div class="h-1.5 bg-white/10 rounded-full overflow-hidden"><div class="h-full bg-amber-400 rounded-full" style="width:100%"></div></div>
                  </div>
                  <div>
                    <div class="flex justify-between mb-1.5"><span class="text-[11px] text-white/75">Transport</span><span class="text-[11px] font-mono text-white">$390 <span class="text-white/35">/ $500</span></span></div>
                    <div class="h-1.5 bg-white/10 rounded-full overflow-hidden"><div class="h-full bg-indigo-400 rounded-full" style="width:78%"></div></div>
                  </div>
                  <div>
                    <div class="flex justify-between mb-1.5"><span class="text-[11px] text-white/75">Subscriptions</span><span class="text-[11px] font-mono text-white">$127 <span class="text-white/35">/ $200</span></span></div>
                    <div class="h-1.5 bg-white/10 rounded-full overflow-hidden"><div class="h-full bg-indigo-400 rounded-full" style="width:64%"></div></div>
                  </div>
                  <div class="pt-1.5 border-t border-white/[0.06] flex justify-between">
                    <span class="text-[10px] text-white/35">3 on track</span>
                    <span class="text-[10px] text-amber-400">1 over budget</span>
                  </div>
                </div>
              </div>

            </div>
          </div>

          <!-- indicator dots -->
          <div class="flex justify-center gap-2 mt-4">
            <div class="dot w-1.5 h-1.5 rounded-full bg-indigo-400" data-index="0"></div>
            <div class="dot w-1.5 h-1.5 rounded-full bg-white/20"   data-index="1"></div>
            <div class="dot w-1.5 h-1.5 rounded-full bg-white/20"   data-index="2"></div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>


<!-- ════════════════════════════════════════════════════════════════
     NOT EVERYONE'S A FINANCE BRO
════════════════════════════════════════════════════════════════ -->
<section class="py-20 px-4 sm:px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Not everyone's a finance bro.</h2>
      <p class="text-white/50 text-lg max-w-xl mx-auto">
        Most people don't want a second job managing their money. They just want to know where it went.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      <div class="glass rounded-2xl card-glow p-6 sm:p-8 border border-white/[0.06]">
        <p class="text-xs uppercase tracking-widest font-semibold text-white/35 mb-5">Before</p>
        <div class="space-y-3.5">
          <div class="flex items-start gap-3"><span class="text-red-400 mt-0.5 flex-shrink-0">✗</span><span class="text-sm text-white/55">Spreadsheet that's already out of date</span></div>
          <div class="flex items-start gap-3"><span class="text-red-400 mt-0.5 flex-shrink-0">✗</span><span class="text-sm text-white/55">Manually entering every transaction</span></div>
          <div class="flex items-start gap-3"><span class="text-red-400 mt-0.5 flex-shrink-0">✗</span><span class="text-sm text-white/55">Checking four different banking apps</span></div>
          <div class="flex items-start gap-3"><span class="text-red-400 mt-0.5 flex-shrink-0">✗</span><span class="text-sm text-white/55">Sunday night catch-up sessions you keep skipping</span></div>
          <div class="flex items-start gap-3"><span class="text-red-400 mt-0.5 flex-shrink-0">✗</span><span class="text-sm text-white/55">Discovering you went over budget after the month ends</span></div>
        </div>
      </div>

      <div class="glass rounded-2xl card-glow p-6 sm:p-8 border border-indigo-500/20"
           style="background: linear-gradient(135deg, rgba(99,102,241,0.08), rgba(32,43,65,0.75));">
        <p class="text-xs uppercase tracking-widest font-semibold text-indigo-400 mb-5">With Vylo</p>
        <div class="space-y-3.5">
          <div class="flex items-start gap-3"><span class="text-emerald-400 mt-0.5 flex-shrink-0">✓</span><span class="text-sm text-white/75">Every transaction categorized automatically</span></div>
          <div class="flex items-start gap-3"><span class="text-emerald-400 mt-0.5 flex-shrink-0">✓</span><span class="text-sm text-white/75">One clear view of where your money went</span></div>
          <div class="flex items-start gap-3"><span class="text-emerald-400 mt-0.5 flex-shrink-0">✓</span><span class="text-sm text-white/75">Budgets that track themselves</span></div>
          <div class="flex items-start gap-3"><span class="text-emerald-400 mt-0.5 flex-shrink-0">✓</span><span class="text-sm text-white/75">Takes two minutes to set up, then runs itself</span></div>
          <div class="flex items-start gap-3"><span class="text-emerald-400 mt-0.5 flex-shrink-0">✓</span><span class="text-sm text-white/75">Know where you stand any time you check</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════════════════════════════════════════════════════════════════
     WHY DIFFERENT
════════════════════════════════════════════════════════════════ -->
<section class="py-20 px-4 sm:px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Designed to stay simple.</h2>
      <p class="text-white/50 text-lg max-w-xl mx-auto">
        Most finance apps kept adding. Vylo kept cutting. Here's what's left.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <div class="glass rounded-xl p-6 card-glow">
        <div class="w-10 h-10 rounded-lg bg-indigo-500/15 flex items-center justify-center mb-4">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2L2 7v6l8 5 8-5V7l-8-5z" stroke="#818cf8" stroke-width="1.5" stroke-linejoin="round"/><path d="M2 7l8 5m0 0l8-5m-8 5v5" stroke="#818cf8" stroke-width="1.5" stroke-linejoin="round"/></svg>
        </div>
        <h3 class="font-semibold text-white text-sm mb-2">Connect once, done forever</h3>
        <p class="text-white/50 text-sm leading-relaxed">Link your bank once. Every transaction pulls in and categorizes itself — no logging in, no tagging, no updates to forget.</p>
      </div>
      <div class="glass rounded-xl p-6 card-glow">
        <div class="w-10 h-10 rounded-lg bg-emerald-500/15 flex items-center justify-center mb-4">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M3 10a7 7 0 1014 0A7 7 0 003 10z" stroke="#34d399" stroke-width="1.5"/><path d="M10 6v4l3 2" stroke="#34d399" stroke-width="1.5" stroke-linecap="round"/></svg>
        </div>
        <h3 class="font-semibold text-white text-sm mb-2">Always up to date</h3>
        <p class="text-white/50 text-sm leading-relaxed">Open Vylo and you'll know exactly where you stand — not an estimate, but the actual number, right now, this month.</p>
      </div>
      <div class="glass rounded-xl p-6 card-glow">
        <div class="w-10 h-10 rounded-lg bg-amber-500/15 flex items-center justify-center mb-4">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4 9a4 4 0 118 0c0 3-2 5-4 6-2-1-4-3-4-6z" stroke="#fbbf24" stroke-width="1.5" stroke-linejoin="round"/><circle cx="8" cy="16" r="1" fill="#fbbf24"/><path d="M12 10a4 4 0 118 0c0 3-2 5-4 6" stroke="#fbbf24" stroke-width="1.5" stroke-linejoin="round"/></svg>
        </div>
        <h3 class="font-semibold text-white text-sm mb-2">Shared view, shared life</h3>
        <p class="text-white/50 text-sm leading-relaxed">Add your partner or housemates. One login each, one picture together. No more "did you pay that?" texts.</p>
      </div>
      <div class="glass rounded-xl p-6 card-glow">
        <div class="w-10 h-10 rounded-lg bg-rose-500/15 flex items-center justify-center mb-4">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><rect x="3" y="7" width="14" height="10" rx="2" stroke="#f87171" stroke-width="1.5"/><path d="M7 7V5a3 3 0 016 0v2" stroke="#f87171" stroke-width="1.5" stroke-linecap="round"/></svg>
        </div>
        <h3 class="font-semibold text-white text-sm mb-2">Bank-grade security</h3>
        <p class="text-white/50 text-sm leading-relaxed">Powered by Plaid. Read-only access. We never see or store your banking credentials.</p>
      </div>
    </div>
  </div>
</section>


<!-- ════════════════════════════════════════════════════════════════
     FEATURES
════════════════════════════════════════════════════════════════ -->
<section id="features" class="py-20 px-4 sm:px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-14">
      <p class="text-indigo-400 text-xs uppercase tracking-widest font-semibold mb-3">Features</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">The right features. None of the wrong ones.</h2>
      <p class="text-white/50 text-lg max-w-xl mx-auto">We built what actually helps you stay on top of your money. The rest got cut.</p>
    </div>

    <div class="space-y-5">

      <!-- Feature 1: Auto-categorization -->
      <div class="glass rounded-2xl card-glow p-6 sm:p-8 grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
        <div>
          <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-indigo-500/10 text-indigo-300 text-xs font-medium mb-4">⚡ Auto-categorization</div>
          <h3 class="text-xl font-semibold text-white mb-3">Every transaction, filed before you even open the app.</h3>
          <p class="text-white/50 text-sm leading-relaxed">The moment a charge posts, Vylo reads the merchant and drops it into the right bucket — groceries, dining, transport, subscriptions. No review queue. No weekend catch-up.</p>
        </div>
        <div class="space-y-2.5 bg-white/[0.02] rounded-xl p-4">
          <div class="flex items-center justify-between p-2.5 rounded-lg bg-white/[0.04] border border-white/[0.06]">
            <div class="flex items-center gap-2.5"><div class="w-7 h-7 rounded-md bg-emerald-500/20 text-emerald-400 text-xs font-bold flex items-center justify-center">T</div><span class="text-sm text-white">Trader Joe's</span></div>
            <span class="text-xs text-emerald-400 bg-emerald-500/10 px-2 py-0.5 rounded-full">Groceries</span>
          </div>
          <div class="flex items-center justify-between p-2.5 rounded-lg bg-white/[0.04] border border-white/[0.06]">
            <div class="flex items-center gap-2.5"><div class="w-7 h-7 rounded-md bg-rose-500/20 text-rose-400 text-xs font-bold flex items-center justify-center">C</div><span class="text-sm text-white">Chipotle</span></div>
            <span class="text-xs text-rose-400 bg-rose-500/10 px-2 py-0.5 rounded-full">Dining out</span>
          </div>
          <div class="flex items-center justify-between p-2.5 rounded-lg bg-white/[0.04] border border-white/[0.06]">
            <div class="flex items-center gap-2.5"><div class="w-7 h-7 rounded-md bg-indigo-500/20 text-indigo-400 text-xs font-bold flex items-center justify-center">S</div><span class="text-sm text-white">Spotify</span></div>
            <span class="text-xs text-indigo-400 bg-indigo-500/10 px-2 py-0.5 rounded-full">Subscriptions</span>
          </div>
        </div>
      </div>

      <!-- Feature 2 + 3 -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div class="glass rounded-2xl card-glow p-6 sm:p-8">
          <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-emerald-500/10 text-emerald-300 text-xs font-medium mb-4">📈 Spend trends</div>
          <h3 class="text-xl font-semibold text-white mb-3">Patterns you didn't know you had.</h3>
          <p class="text-white/50 text-sm leading-relaxed mb-5">Week over week, month over month — the chart tells the story your bank statement buries in a list.</p>
          <div class="flex items-end gap-1.5 h-16 px-1">
            <div class="flex-1 rounded-t-sm" style="height:38%; background:rgba(99,102,241,.22)"></div>
            <div class="flex-1 rounded-t-sm" style="height:62%; background:rgba(99,102,241,.30)"></div>
            <div class="flex-1 rounded-t-sm" style="height:45%; background:rgba(99,102,241,.22)"></div>
            <div class="flex-1 rounded-t-sm" style="height:82%; background:rgba(99,102,241,.40)"></div>
            <div class="flex-1 rounded-t-sm" style="height:54%; background:rgba(99,102,241,.30)"></div>
            <div class="flex-1 rounded-t-sm" style="height:95%; background:#6366f1"></div>
          </div>
        </div>
        <div class="glass rounded-2xl card-glow p-6 sm:p-8">
          <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-amber-500/10 text-amber-300 text-xs font-medium mb-4">🎯 Budget tracking</div>
          <h3 class="text-xl font-semibold text-white mb-3">Set a limit. Know when you're close.</h3>
          <p class="text-white/50 text-sm leading-relaxed mb-5">Budget per category. Vylo watches the number so you don't have to. When you're getting close, you'll know.</p>
          <div class="space-y-3">
            <div>
              <div class="flex justify-between mb-1.5"><span class="text-xs text-white/60">Groceries</span><span class="text-xs font-mono text-white">$842 / $1,000</span></div>
              <div class="h-1.5 bg-white/10 rounded-full"><div class="h-full bg-emerald-400 rounded-full" style="width:84%"></div></div>
            </div>
            <div>
              <div class="flex justify-between mb-1.5"><span class="text-xs text-white/60">Dining out</span><span class="text-xs font-mono text-amber-400">Over budget</span></div>
              <div class="h-1.5 bg-white/10 rounded-full"><div class="h-full bg-amber-400 rounded-full" style="width:100%"></div></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Feature 4 + 5 -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div class="glass rounded-2xl card-glow p-6 sm:p-8">
          <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-violet-500/10 text-violet-300 text-xs font-medium mb-4">👥 Household members</div>
          <h3 class="text-xl font-semibold text-white mb-3">Everyone on the same page.</h3>
