---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?:       string;
  description?: string;
  currentPage?: string;
}

const {
  title       = 'Vylo — Household finance, without the headache',
  description = 'Connect your bank. Every transaction categorizes itself. Your whole household gets one clear, real-time view of where the money went — no spreadsheets, no manual entry.',
  currentPage = '',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>

  <!-- Favicons -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=20260309" />
  <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32.png?v=20260309" />
  <link rel="icon" type="image/png" sizes="16x16" href="/icons/favicon-16.png?v=20260309" />
  <link rel="shortcut icon" href="/icons/favicon.ico?v=20260309" />
  <link rel="apple-touch-icon" sizes="180x180" href="/icons/apple-touch-icon.png" />
  <link rel="apple-touch-icon" sizes="152x152" href="/icons/apple-touch-icon-152.png" />
  <link rel="apple-touch-icon" sizes="120x120" href="/icons/apple-touch-icon-120.png" />
  <meta name="theme-color" content="#1a2437" />

  <!-- OG / Social -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content="https://www.myvylo.com/" />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content="https://www.myvylo.com/icons/icon-512.png" />
  <meta name="twitter:card"       content="summary" />
  <meta name="twitter:title"      content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"      content="https://www.myvylo.com/icons/icon-512.png" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body class="antialiased">
  <Nav currentPage={currentPage} />
  <slot />
  <Footer />
</body>
</html>
